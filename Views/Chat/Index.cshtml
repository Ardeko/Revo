@{
    Layout = null;
    string username = ViewBag.Username ?? "Misafir";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>REVO — Oda</title>
    <link rel="icon" type="image/png" href="~/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0B0E13;
            --panel: #151A21;
            --panel-2: #1C232C;
            --panel-3: #222A34;
            --border: #262E38;
            --border-soft: #1e252e;
            --text: #EDEBE6;
            --text-dim: #8A93A3;
            --text-faint: #545E6C;
            --amber: #E3A857;
            --amber-soft: rgba(227, 168, 87, 0.14);
            --signal: #3ECFC0;
            --signal-soft: rgba(62, 207, 192, 0.14);
            --danger: #C1594A;
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            height: 100%;
            background:
                radial-gradient(circle at 50% 0%, #151b24 0%, var(--bg) 45%),
                var(--bg);
            color: var(--text);
            font-family: 'IBM Plex Sans', sans-serif;
        }

        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 8px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--panel-3); }

        .app {
            display: flex;
            flex-direction: column;
            height: 100vh;
            max-width: 1000px;
            margin: 0 auto;
            opacity: 0;
            animation: fade-in 0.5s ease 0.05s forwards;
        }

        @@keyframes fade-in {
            to { opacity: 1; }
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 14px 22px;
            border-bottom: 1px solid var(--border-soft);
            flex-shrink: 0;
        }

        .brand-lockup {
    display: flex;
    align-items: center;
    gap: 14px;
    background: linear-gradient(90deg, rgba(28, 35, 44, 0.6), transparent);
    padding: 6px 20px 6px 10px;
    border-left: 3px solid var(--amber);
    border-radius: 4px 16px 16px 4px;
    box-shadow: inset 1px 0 0 rgba(255,255,255,0.05);
}

.brand-lockup img {
    height: 36px;
    width: auto;
    filter: drop-shadow(0 0 4px rgba(227, 168, 87, 0.25));
    transition: filter 0.3s ease;
}

.brand-lockup:hover img {
    filter: drop-shadow(0 0 8px var(--amber));
}

        .brand {
            font-family: 'Big Shoulders Display', sans-serif;
            font-weight: 800;
            font-size: 24px;
            letter-spacing: 1.5px;
            background: linear-gradient(180deg, var(--text) 0%, var(--amber) 160%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .status {
            display: flex;
            align-items: center;
            gap: 9px;
            font-family: 'IBM Plex Mono', monospace;
            font-size: 11px;
            color: var(--text-dim);
            letter-spacing: 0.8px;
            text-transform: uppercase;
            padding: 6px 12px;
            border: 1px solid var(--border-soft);
            border-radius: 999px;
            background: rgba(21, 26, 33, 0.6);
        }

        .status-dot-wrap {
            position: relative;
            width: 8px;
            height: 8px;
            flex-shrink: 0;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--danger);
            display: block;
            position: relative;
            z-index: 1;
            transition: background 0.3s ease;
        }

        .status-dot.connected {
            background: var(--signal);
            box-shadow: 0 0 8px var(--signal);
        }

        .status-dot.connected::after {
            content: "";
            position: absolute;
            inset: -5px;
            border-radius: 50%;
            border: 1px solid var(--signal);
            opacity: 0.6;
            animation: ripple 1.8s ease-out infinite;
        }

        @@keyframes ripple {
            0% { transform: scale(0.4); opacity: 0.7; }
            100% { transform: scale(2.4); opacity: 0; }
        }

        .count {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 11px;
            color: var(--text-dim);
            letter-spacing: 0.5px;
            padding: 6px 12px;
            border: 1px solid var(--border-soft);
            border-radius: 999px;
            background: rgba(21, 26, 33, 0.6);
            white-space: nowrap;
        }

        .room {
            flex: 1;
            display: grid;
            grid-template-columns: 232px 1fr;
            gap: 14px;
            padding: 14px;
            min-height: 0;
        }

        .panel {
            background: linear-gradient(180deg, var(--panel) 0%, #131820 100%);
            border: 1px solid var(--border-soft);
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            min-height: 0;
            padding: 16px;
        }

        .panel-title {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 10.5px;
            text-transform: uppercase;
            letter-spacing: 1.8px;
            color: var(--text-faint);
            margin: 0 0 14px 0;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .panel-title::before {
            content: "";
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--signal);
        }

        .participant-list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 7px;
            overflow-y: auto;
        }

        .participant {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 9px 11px;
            border-radius: 11px;
            background: var(--panel-2);
            border: 1px solid transparent;
            transition: border-color 0.2s ease, background 0.2s ease;
            animation: row-in 0.35s cubic-bezier(.16,.8,.3,1);
        }

        @@keyframes row-in {
            from { opacity: 0; transform: translateX(-6px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .participant.speaking {
            border-color: var(--signal-soft);
            background: linear-gradient(90deg, rgba(62,207,192,0.08), var(--panel-2) 55%);
        }

        .participant .name {
            flex: 1;
            font-size: 13px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .participant.you .name {
            color: var(--amber);
            font-weight: 600;
        }

        .participant .meter {
            display: flex;
            align-items: flex-end;
            gap: 2px;
            height: 14px;
            flex-shrink: 0;
        }

        .meter .bar {
            width: 3px;
            height: 3px;
            background: var(--signal);
            border-radius: 1px;
            opacity: 0.35;
            transition: height 0.08s ease-out;
        }

        .participant.speaking .meter .bar {
            opacity: 1;
        }

        .participant .muted-icon {
            display: none;
            font-size: 12px;
            opacity: 0.85;
        }

        .participant.muted .muted-icon {
            display: inline;
        }

        .participant .pending {
            font-size: 10px;
            color: var(--text-faint);
            font-family: 'IBM Plex Mono', monospace;
            white-space: nowrap;
        }

        .chat-panel .messages {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 3px;
            margin-bottom: 12px;
            min-height: 0;
        }

        .message {
            font-size: 14px;
            line-height: 1.5;
            word-break: break-word;
            padding: 5px 2px;
            animation: row-in 0.3s cubic-bezier(.16,.8,.3,1);
        }

        .message .who {
            color: var(--amber);
            font-weight: 600;
            margin-right: 4px;
        }

        .message.system {
            color: var(--text-faint);
            font-style: italic;
            font-size: 12.5px;
        }

        .message-form {
            display: flex;
            gap: 8px;
            flex-shrink: 0;
        }

        .message-form input {
            flex: 1;
            padding: 11px 14px;
            border-radius: 11px;
            border: 1px solid var(--border);
            background: var(--panel-2);
            color: var(--text);
            font-family: inherit;
            font-size: 14px;
            min-width: 0;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .message-form input:hover {
            border-color: #33404d;
        }

        .message-form input:focus {
            outline: none;
            border-color: var(--amber);
            box-shadow: 0 0 0 3px var(--amber-soft);
        }

        .message-form button {
            padding: 11px 18px;
            border-radius: 11px;
            border: none;
            background: var(--amber);
            color: #241a0d;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: filter 0.15s, transform 0.1s;
        }

        .message-form button:hover { filter: brightness(1.1); }
        .message-form button:active { transform: scale(0.97); }

        .controls {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 18px;
            padding: 16px;
            border-top: 1px solid var(--border-soft);
            flex-shrink: 0;
            position: relative;
        }

        .mic-button {
            position: relative;
            width: 54px;
            height: 54px;
            border-radius: 50%;
            border: 2px solid var(--signal);
            background: var(--panel-2);
            color: var(--signal);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s;
            padding: 0;
        }

        .mic-button::after {
            content: "";
            position: absolute;
            inset: -6px;
            border-radius: 50%;
            border: 1px solid var(--signal);
            opacity: 0;
            transition: opacity 0.2s ease;
        }

        .mic-button:not([aria-pressed="true"])::after {
            opacity: 0.35;
            animation: ripple 2.4s ease-out infinite;
        }

        .mic-button svg { width: 22px; height: 22px; }

        .mic-button:hover { filter: brightness(1.15); transform: scale(1.03); }

        .mic-button[aria-pressed="true"] {
            border-color: var(--danger);
            color: var(--danger);
            background: rgba(193, 89, 74, 0.12);
        }

        .mic-button[aria-pressed="true"]::after { display: none; }

        .leave-button {
            padding: 13px 20px;
            border-radius: 11px;
            border: 1px solid var(--danger);
            background: transparent;
            color: var(--danger);
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            font-size: 14px;
            transition: background 0.15s, transform 0.1s;
        }

        .leave-button:hover { background: rgba(193, 89, 74, 0.12); }
        .leave-button:active { transform: scale(0.97); }

        /* ---------- Ardeko Studios credit ---------- */

        .credit {
            position: absolute;
            right: 18px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            opacity: 0.45;
            text-decoration: none;
            transition: opacity 0.2s ease;
        }

        .credit:hover { opacity: 0.9; }

        .credit img {
            height: 26px;
            width: auto;
        }

        .credit span {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 9.5px;
            letter-spacing: 1.4px;
            text-transform: uppercase;
            color: var(--text-faint);
        }

        @@media (max-width: 640px) {
            .room {
                grid-template-columns: 1fr;
                grid-template-rows: auto 1fr;
            }

            .participants-panel {
                max-height: 140px;
            }

            .participant-list {
                flex-direction: row;
                flex-wrap: wrap;
            }

            .participant {
                flex: 0 0 auto;
            }

            .credit {
                position: static;
                margin-top: 10px;
            }

            .controls {
                flex-wrap: wrap;
            }
        }

        @@media (prefers-reduced-motion: reduce) {
            * { animation: none !important; transition: none !important; }
        }
    </style>
</head>
<body>
    <div class="app">
        <header class="topbar">
            <div class="brand-lockup">
                <img src="/img/ardeko.png" alt="" />
                <span class="brand">REVO</span>
            </div>
            <div class="status">
                <span class="status-dot-wrap"><span class="status-dot" id="statusDot"></span></span>
                <span id="statusText">BAĞLANIYOR</span>
            </div>
            <div class="count" id="participantCount">1 kişi</div>
        </header>

        <main class="room">
            <section class="panel participants-panel">
                <h2 class="panel-title">Frekansta</h2>
                <ul class="participant-list" id="participantList"></ul>
            </section>

            <section class="panel chat-panel">
                <h2 class="panel-title">Sohbet</h2>
                <div class="messages" id="messagesList"></div>
                <form class="message-form" id="messageForm">
                    <input type="text" id="messageInput" placeholder="Mesaj yaz…" autocomplete="off" maxlength="500" />
                    <button type="submit">Gönder</button>
                </form>
            </section>
        </main>

        <footer class="controls">
            <button id="muteButton" class="mic-button" type="button" aria-pressed="false" aria-label="Mikrofonu kapat">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                    <line x1="12" y1="19" x2="12" y2="23"></line>
                    <line x1="8" y1="23" x2="16" y2="23"></line>
                </svg>
            </button>
            <button id="leaveButton" class="leave-button" type="button">Odadan Çık</button>

            <a class="credit" href="#" tabindex="-1" aria-hidden="true">
    <img src="/img/ardeko.png" alt="" /> <span>Ardeko Studios</span>
</a>
        </footer>
    </div>

    <div id="remoteAudios" style="display:none;" aria-hidden="true"></div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        (function () {
            // ViewBag.Username'i JSON olarak güvenli biçimde JS string'ine gömüyoruz.
            // (Eski koddaki "@@username" doğrudan gömme yöntemi, nick içinde tırnak veya
            // script kapatma etiketi gibi karakterler olursa sayfayı kırabiliyordu.)
            const currentUsername = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(username));

            const configuration = {
                iceServers: [{ urls: "stun:stun.l.google.com:19302" }]
            };

            let localStream = null;
            let isMuted = false;
            let sharedAudioCtx = null;

            // connectionId -> { username, pc, audioEl, muted }
            const participants = new Map();

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .withAutomaticReconnect()
                .build();

            // ---------- Küçük UI yardımcıları ----------

            function setStatus(connected) {
                document.getElementById("statusDot").classList.toggle("connected", connected);
                document.getElementById("statusText").textContent = connected ? "SİNYAL VAR" : "BAĞLANIYOR";
            }

            function appendSystemMessage(text) {
                const el = document.createElement("div");
                el.className = "message system";
                el.textContent = text;
                const list = document.getElementById("messagesList");
                list.appendChild(el);
                list.scrollTop = list.scrollHeight;
            }

            function appendChatMessage(user, text) {
                const el = document.createElement("div");
                el.className = "message";
                const who = document.createElement("span");
                who.className = "who";
                who.textContent = user + ":";
                el.appendChild(who);
                el.appendChild(document.createTextNode(" " + text));
                const list = document.getElementById("messagesList");
                list.appendChild(el);
                list.scrollTop = list.scrollHeight;
            }

            function buildParticipantRow(connectionId, name, isYou, muted, status) {
                const li = document.createElement("li");
                li.className = "participant" + (isYou ? " you" : "") + (muted ? " muted" : "");
                li.dataset.connectionId = connectionId;

                const nameEl = document.createElement("span");
                nameEl.className = "name";
                nameEl.textContent = isYou ? `${name} (Sen)` : name;
                li.appendChild(nameEl);

                if (!isYou && status !== "connected") {
                    const isTrouble = status === "failed" || status === "disconnected" || status === "closed";
                    const badge = document.createElement("span");
                    badge.className = "pending";
                    badge.textContent = isTrouble ? "bağlantı sorunu" : "bağlanıyor…";
                    li.appendChild(badge);
                }

                const mutedIcon = document.createElement("span");
                mutedIcon.className = "muted-icon";
                mutedIcon.textContent = "🔇";
                li.appendChild(mutedIcon);

                const meter = document.createElement("span");
                meter.className = "meter";
                for (let i = 0; i < 3; i++) {
                    const bar = document.createElement("span");
                    bar.className = "bar";
                    meter.appendChild(bar);
                }
                li.appendChild(meter);

                return li;
            }

            function renderParticipantList() {
                const list = document.getElementById("participantList");
                list.innerHTML = "";
                list.appendChild(buildParticipantRow("__self__", currentUsername, true, isMuted, "connected"));

                for (const [connectionId, p] of participants.entries()) {
                    const status = p.pc ? p.pc.connectionState : "pending";
                    list.appendChild(buildParticipantRow(connectionId, p.username, false, p.muted, status));
                }

                document.getElementById("participantCount").textContent = `${participants.size + 1} kişi`;
            }

            function applyLevelToRow(connectionId, level) {
                const row = document.querySelector(`.participant[data-connection-id="${CSS.escape(connectionId)}"]`);
                if (!row) return;
                const bars = row.querySelectorAll(".meter .bar");
                const heights = [4, 8, 14];
                bars.forEach((bar, i) => {
                    const active = level > (i + 1) * 0.18;
                    bar.style.height = active ? `${heights[i]}px` : "3px";
                });
                row.classList.toggle("speaking", level > 0.12);
            }

            function startLevelMeter(stream, connectionId) {
                if (!sharedAudioCtx) {
                    sharedAudioCtx = new (window.AudioContext || window.webkitAudioContext)();
                }
                if (sharedAudioCtx.state === "suspended") {
                    sharedAudioCtx.resume().catch(() => {});
                }

                const source = sharedAudioCtx.createMediaStreamSource(stream);
                const analyser = sharedAudioCtx.createAnalyser();
                analyser.fftSize = 256;
                analyser.smoothingTimeConstant = 0.6;
                source.connect(analyser);
                const data = new Uint8Array(analyser.frequencyBinCount);

                (function tick() {
                    analyser.getByteFrequencyData(data);
                    const avg = data.reduce((a, b) => a + b, 0) / data.length;
                    applyLevelToRow(connectionId, Math.min(1, avg / 60));
                    requestAnimationFrame(tick);
                })();
            }

            // ---------- Oda / WebRTC durumu ----------

            function getOrCreateParticipant(connectionId, name) {
                let p = participants.get(connectionId);
                if (!p) {
                    p = { username: name || "Katılımcı", pc: null, audioEl: null, muted: false };
                    participants.set(connectionId, p);
                } else if (name) {
                    p.username = name;
                }
                return p;
            }

            // Her uzak katılımcı için AYRI bir RTCPeerConnection tutuyoruz (mesh topoloji).
            // Eski koddaki tek global "peerConnection" değişkeni, 2. bir kişi bağlanmaya
            // çalıştığında ilk bağlantının üzerine yazılıyor ve iki bağlantıyı da bozuyordu.
            function createPeerConnectionFor(connectionId) {
                const p = getOrCreateParticipant(connectionId);
                if (p.pc) return p.pc;

                const pc = new RTCPeerConnection(configuration);

                pc.onicecandidate = (event) => {
                    if (event.candidate) {
                        connection.invoke("SendICECandidate", connectionId, JSON.stringify(event.candidate))
                            .catch(err => console.error("ICE gönderim hatası:", err));
                    }
                };

                pc.ontrack = (event) => {
                    if (!p.audioEl) {
                        const audioEl = document.createElement("audio");
                        audioEl.autoplay = true;
                        document.getElementById("remoteAudios").appendChild(audioEl);
                        p.audioEl = audioEl;
                    }
                    if (p.audioEl.srcObject !== event.streams[0]) {
                        p.audioEl.srcObject = event.streams[0];
                    }
                    startLevelMeter(event.streams[0], connectionId);
                };

                pc.onconnectionstatechange = () => renderParticipantList();

                if (localStream) {
                    localStream.getTracks().forEach(track => pc.addTrack(track, localStream));
                }

                p.pc = pc;
                renderParticipantList();
                return pc;
            }

            async function ensureLocalStream() {
                if (localStream) return localStream;
                localStream = await navigator.mediaDevices.getUserMedia({ audio: true });
                startLevelMeter(localStream, "__self__");
                return localStream;
            }

            async function callUser(connectionId) {
                const pc = createPeerConnectionFor(connectionId);
                const offer = await pc.createOffer();
                await pc.setLocalDescription(offer);
                await connection.invoke("SendOffer", connectionId, JSON.stringify(offer));
            }

            function teardownParticipant(connectionId) {
                const p = participants.get(connectionId);
                if (!p) return;
                if (p.pc) p.pc.close();
                if (p.audioEl) p.audioEl.remove();
                participants.delete(connectionId);
            }

            // ---------- SignalR olayları ----------

            connection.on("ExistingUsers", async (users) => {
                try {
                    await ensureLocalStream();
                } catch (err) {
                    console.error("Mikrofon erişim hatası:", err);
                    alert("Odaya sesli katılmak için mikrofon erişimine izin vermelisin.");
                    return;
                }
                for (const u of users) {
                    getOrCreateParticipant(u.connectionId, u.username);
                    await callUser(u.connectionId);
                }
                renderParticipantList();
            });

            connection.on("UserJoined", (connectionId, name) => {
                getOrCreateParticipant(connectionId, name);
                renderParticipantList();
                appendSystemMessage(`${name} odaya katıldı.`);
            });

            connection.on("ReceiveOffer", async (senderConnectionId, offerStr) => {
                try {
                    await ensureLocalStream();
                } catch (err) {
                    console.error("Mikrofon erişim hatası:", err);
                    alert("Odaya sesli katılmak için mikrofon erişimine izin vermelisin.");
                    return;
                }
                const offer = JSON.parse(offerStr);
                const pc = createPeerConnectionFor(senderConnectionId);
                await pc.setRemoteDescription(new RTCSessionDescription(offer));
                const answer = await pc.createAnswer();
                await pc.setLocalDescription(answer);
                await connection.invoke("SendAnswer", senderConnectionId, JSON.stringify(answer));
            });

            connection.on("ReceiveAnswer", async (senderConnectionId, answerStr) => {
                const p = participants.get(senderConnectionId);
                if (!p || !p.pc) return;
                await p.pc.setRemoteDescription(new RTCSessionDescription(JSON.parse(answerStr)));
            });

            connection.on("ReceiveICECandidate", async (senderConnectionId, candidateStr) => {
                const p = participants.get(senderConnectionId);
                if (!p || !p.pc) return;
                try {
                    await p.pc.addIceCandidate(new RTCIceCandidate(JSON.parse(candidateStr)));
                } catch (e) {
                    console.error("ICE ekleme hatası:", e);
                }
            });

            connection.on("UserMuteChanged", (connectionId, muted) => {
                const p = participants.get(connectionId);
                if (p) {
                    p.muted = muted;
                    renderParticipantList();
                }
            });

            connection.on("UserLeft", (connectionId, name) => {
                teardownParticipant(connectionId);
                renderParticipantList();
                appendSystemMessage(`${name} odadan ayrıldı.`);
            });

            connection.on("ReceiveMessage", (user, message) => {
                appendChatMessage(user, message);
            });

            // ---------- Kontroller ----------

            document.getElementById("messageForm").addEventListener("submit", (e) => {
                e.preventDefault();
                const input = document.getElementById("messageInput");
                const message = input.value.trim();
                if (!message) return;
                connection.invoke("SendMessage", message).catch(err => console.error("Mesaj gönderim hatası:", err));
                input.value = "";
            });

            document.getElementById("muteButton").addEventListener("click", async () => {
                try {
                    await ensureLocalStream();
                } catch (err) {
                    alert("Mikrofona erişim izni vermelisin.");
                    return;
                }
                isMuted = !isMuted;
                localStream.getAudioTracks().forEach(track => track.enabled = !isMuted);
                const btn = document.getElementById("muteButton");
                btn.setAttribute("aria-pressed", String(isMuted));
                btn.setAttribute("aria-label", isMuted ? "Mikrofonu aç" : "Mikrofonu kapat");
                connection.invoke("ToggleMute", isMuted).catch(err => console.error("Mute bildirim hatası:", err));
                renderParticipantList();
            });

            document.getElementById("leaveButton").addEventListener("click", () => {
                window.location.href = "/Chat/Login";
            });

            window.addEventListener("beforeunload", () => {
                if (localStream) {
                    localStream.getTracks().forEach(track => track.stop());
                }
                participants.forEach(p => p.pc && p.pc.close());
            });

            // ---------- Başlangıç ----------

            connection.start()
                .then(() => {
                    setStatus(true);
                    return connection.invoke("JoinRoom", currentUsername);
                })
                .then(() => renderParticipantList())
                .catch(err => {
                    console.error("SignalR bağlantı hatası:", err);
                    setStatus(false);
                    appendSystemMessage("Bağlantı kurulamadı, sayfayı yenilemeyi dene.");
                });

            connection.onreconnecting(() => setStatus(false));

            connection.onreconnected(() => {
                // Reconnect sonrası SignalR yeni bir ConnectionId atar; eski peer
                // bağlantıları artık sunucu tarafında anlamsız kaldığı için hepsini
                // kapatıp odaya yeniden katılarak mesh'i sıfırdan kuruyoruz.
                setStatus(true);
                participants.forEach((p, id) => teardownParticipant(id));
                connection.invoke("JoinRoom", currentUsername).then(() => renderParticipantList());
            });

            renderParticipantList();
        })();
    </script>
</body>
</html>
